<?xml version="1.0" encoding="utf-8"?>
<!--
    [ScrollView - 스크롤 가능한 컨테이너]

    화면에 다 담을 수 없는 많은 콘텐츠가 있을 때 사용한다.
    ScrollView는 자식 뷰를 하나만 가질 수 있으므로,
    내부에 LinearLayout을 넣고 그 안에 여러 항목을 배치한다.

    Unity 비유: Scroll Rect 컴포넌트 + Content에 Vertical Layout Group을 넣는 구조.

    [constraintWidth_percent - 비율 기반 크기 조절]
    이 화면에서는 각 설정 항목의 너비를 화면 비율(%)로 설정한다.
    예: layout_constraintWidth_percent="0.9" → 화면 너비의 90%
    Guideline 없이도 비율 기반 크기를 적용할 수 있는 방식.
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    tools:context=".SettingActivity">

    <!--
        ScrollView는 자식을 하나만 가질 수 있다.
        그래서 LinearLayout으로 감싸고, 그 안에 여러 항목을 넣는다.
    -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="설정"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />

        <!-- 설정 항목들: 스크롤을 확인하기 위해 여러 개 배치 -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="계정"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#666666"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="프로필 편집"
            android:textSize="18sp"
            android:gravity="center_vertical" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="비밀번호 변경"
            android:textSize="18sp"
            android:gravity="center_vertical" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="이메일 변경"
            android:textSize="18sp"
            android:gravity="center_vertical" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginVertical="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="알림"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#666666"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="푸시 알림"
            android:textSize="18sp"
            android:gravity="center_vertical" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="이메일 알림"
            android:textSize="18sp"
            android:gravity="center_vertical" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="마케팅 수신 동의"
            android:textSize="18sp"
            android:gravity="center_vertical" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginVertical="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="일반"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#666666"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="언어 설정"
            android:textSize="18sp"
            android:gravity="center_vertical" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="다크 모드"
            android:textSize="18sp"
            android:gravity="center_vertical" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="글꼴 크기"
            android:textSize="18sp"
            android:gravity="center_vertical" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="캐시 삭제"
            android:textSize="18sp"
            android:gravity="center_vertical" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginVertical="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="기타"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#666666"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="이용약관"
            android:textSize="18sp"
            android:gravity="center_vertical" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="개인정보 처리방침"
            android:textSize="18sp"
            android:gravity="center_vertical" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="앱 버전"
            android:textSize="18sp"
            android:gravity="center_vertical" />

        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="로그아웃"
            android:layout_marginTop="24dp" />

    </LinearLayout>

</ScrollView>
