<?xml version="1.0" encoding="utf-8"?>
<!-- "+ 게임 추가"를 누르면 화면 아래에서 올라오는 추가 방법 선택 BottomSheet -->
<!-- 검색으로 추가(RAWG API) / 직접 입력(수동 폼) 중 하나를 고른다 -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="8dp"
    android:paddingBottom="16dp">

    <!-- 상단 제목 -->
    <TextView
        android:id="@+id/textViewSheetTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:text="@string/add_game_sheet_title"
        android:textSize="16sp"
        android:textStyle="bold" />

    <!-- 제목과 메뉴 항목을 구분하는 얇은 선 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?android:attr/listDivider" />

    <!-- 검색으로 추가 (RAWG API로 제목·표지·장르 자동 채움) -->
    <TextView
        android:id="@+id/actionSearchAdd"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:text="@string/add_game_sheet_search"
        android:textSize="16sp"
        android:background="?attr/selectableItemBackground" />

    <!-- 둘러보기 (인기/신작/장르별 탐색 → 골라서 추가) -->
    <TextView
        android:id="@+id/actionExplore"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:text="@string/add_game_sheet_explore"
        android:textSize="16sp"
        android:background="?attr/selectableItemBackground" />

    <!-- 직접 입력 (기존 수동 입력 폼) -->
    <TextView
        android:id="@+id/actionManualAdd"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:text="@string/add_game_sheet_manual"
        android:textSize="16sp"
        android:background="?attr/selectableItemBackground" />
</LinearLayout>
