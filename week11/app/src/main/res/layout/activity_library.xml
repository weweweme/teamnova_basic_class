<?xml version="1.0" encoding="utf-8"?>
<!-- 라이브러리 화면 레이아웃 -->
<!-- 상단: 상태별 필터 탭(TabLayout) / 하단: 게임 표지 격자(RecyclerView + GridLayoutManager) -->
<!-- 탭을 누르면 해당 상태의 게임만 격자에 표시됨 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".library.LibraryActivity">

    <!-- 상태별 필터 탭 (전체/플레이중/완료/중단/백로그) -->
    <!-- 탭이 많아 가로로 넘칠 수 있으니 tabMode=scrollable -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayoutFilter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:tabMode="scrollable" />

    <!-- 장르 칩 필터 (상태 탭 + 장르 = 2차원 필터) -->
    <!-- 가로 스크롤 한 줄, 단일 선택. 칩은 코드에서 동적 생성 -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:scrollbars="none">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupGenre"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleLine="true" />
    </HorizontalScrollView>

    <!-- 최근 검색어 (검색창을 펼쳤는데 입력이 비어 있을 때만 코드에서 표시) -->
    <!-- 칩을 누르면 그 검색어로 다시 검색됨 -->
    <LinearLayout
        android:id="@+id/layoutRecentSearch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:visibility="gone">

        <!-- 제목 줄: "최근 검색" + 오른쪽 끝 "지우기" -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/library_recent_search_label"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textViewClearRecentSearch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackground"
                android:padding="6dp"
                android:text="@string/library_recent_search_clear"
                android:textColor="#888888"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- 최근 검색어 칩들 (코드에서 동적 생성) -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupRecentSearch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:singleLine="true" />
        </HorizontalScrollView>
    </LinearLayout>

    <!-- 표지 격자 영역 (탭으로 필터된 게임 표시) -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerViewLibrary"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="6dp"
            android:clipToPadding="false"
            tools:listitem="@layout/item_library_grid" />

        <!-- 빈 상태 안내 (해당 상태의 게임이 없을 때만 표시) -->
        <TextView
            android:id="@+id/textViewEmpty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/library_empty"
            android:textColor="#888888"
            android:textSize="15sp"
            android:visibility="gone" />

        <!-- 정렬 FAB: 우하단 플로팅 버튼 → 탭하면 정렬 옵션 다이얼로그 -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabSort"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_margin="16dp"
            android:src="@android:drawable/ic_menu_sort_by_size"
            android:contentDescription="@string/library_sort" />
    </FrameLayout>

</LinearLayout>
