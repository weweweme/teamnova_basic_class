<?xml version="1.0" encoding="utf-8"?>
<!--
    [HomeActivity 레이아웃 - 앱의 메인 허브 화면]

    ── Android 레이아웃의 기본 구성요소 ──

    ScrollView  = 내용이 화면보다 길 때 스크롤을 가능하게 해주는 컨테이너.
                  자식 뷰를 1개만 가질 수 있다.

    LinearLayout = 자식 뷰를 한 방향으로 순서대로 배치하는 컨테이너.
                   orientation="vertical"이면 위→아래, "horizontal"이면 좌→우.
                   Unity 비유: VerticalLayoutGroup / HorizontalLayoutGroup.

    TextView     = 텍스트를 표시하는 뷰. Unity의 TextMeshPro (TMP_Text).
    Button       = 클릭 가능한 버튼. Unity의 Button + TextMeshPro.
    View         = 아무 기능 없는 빈 뷰. 여기서는 1dp 높이로 구분선에 사용.
                   Unity의 빈 Image (색만 입힌 구분선).

    ── 크기 관련 속성 ──

    layout_width / layout_height = 뷰의 가로/세로 크기.
      "match_parent" → 부모 크기를 꽉 채움 (Unity: Stretch)
      "wrap_content" → 내용물 크기에 맞춤 (Unity: Content Size Fitter - Preferred)
      "200dp"        → 고정 크기 (Unity: Width/Height를 직접 숫자로 지정)

    padding = 뷰 안쪽 여백. 자신의 테두리 ↔ 자식 사이 거리.
    margin  = 뷰 바깥 여백. 자신 ↔ 이웃 뷰 사이 거리.

    차이:  [  margin  [  border  [  padding  [ 내용 ]  padding  ]  border  ]  margin  ]
           ← 바깥 여백 →← 안쪽 여백 →

    ── 이 화면의 구조 ──

    ScrollView (화면 전체, 스크롤 가능)
    └── LinearLayout (vertical, 위→아래 배치, padding=24dp)
        ├── TextView "Android Layout 학습"    ← 타이틀
        ├── TextView "각 버튼을 눌러..."       ← 부제
        ├── TextView "레이아웃 학습"           ← 섹션 1 헤더
        ├── Button 1~5                       ← 레이아웃 데모 버튼들
        ├── View (1dp 구분선)
        ├── TextView "Manifest 학습"          ← 섹션 2 헤더
        └── Button 6~10                      ← Manifest 데모 버튼들
-->

<!--
    [ScrollView]
    내용이 화면보다 길면 손가락으로 위아래 스크롤 가능.
    자식을 1개만 가질 수 있어서 LinearLayout으로 감싼다.
    fillViewport="true" → 내용이 짧아도 화면 전체를 채움 (아래 여백 방지).
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    tools:context=".HomeActivity">

    <!--
        [LinearLayout]
        자식들을 위→아래(vertical)로 순서대로 배치.
        padding="24dp" → 안쪽 상하좌우 24dp 여백 (자식이 화면 끝에 붙지 않게).
        gravity="center_horizontal" → 자식들을 수평 중앙 정렬.
    -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="8dp"
            android:text="Android Layout 학습"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:layout_weight="0"
            android:text="각 버튼을 눌러 레이아웃 데모를 확인하세요"
            android:textSize="14sp" />

        <!-- ═══════════ 레이아웃 학습 섹션 ═══════════ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="레이아웃 학습"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnLogin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="1. 카카오톡 로그인" />

        <Button
            android:id="@+id/btnProfile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="2. 인스타그램 프로필"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="3. 쿠팡 상품 상세"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnCalculator"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="4. 계산기"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="5. 뮤직 플레이어"
            android:layout_marginBottom="16dp" />

        <!-- ═══════════ 구분선 ═══════════ -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginBottom="16dp" />

        <!-- ═══════════ Manifest 학습 섹션 ═══════════ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Manifest 학습"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnCamera"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="6. 카메라"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnPortrait"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="7. 화면 속성"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnFullScreen"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="8. 전체화면"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnLaunchMode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="9. 실행 모드"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnServiceReceiver"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="10. 서비스 / 리시버"
            android:layout_marginBottom="8dp" />

    </LinearLayout>
</ScrollView>
