<?xml version="1.0" encoding="utf-8"?>
<!-- 메인 화면 레이아웃 -->
<!-- 게임 카드 리스트를 ScrollView로 표시 -->
<!-- 9주차에서 RecyclerView로 교체 예정 -->
<!-- Unity로 비유하면 ScrollView Content 안에 Prefab을 Instantiate하는 구조 -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".MainActivity">

    <!-- 상단 타이틀 -->
    <TextView
        android:id="@+id/textViewTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:text="@string/main_title"
        android:textSize="24sp"
        android:textStyle="bold" />

    <!-- 게임 카드 리스트 영역 -->
    <!-- ScrollView는 자식을 하나만 가질 수 있으므로 LinearLayout으로 감쌈 -->
    <ScrollView
        android:id="@+id/scrollViewGames"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- 게임 카드들이 동적으로 추가되는 컨테이너 -->
        <!-- Unity로 비유하면 ScrollView의 Content 오브젝트 -->
        <LinearLayout
            android:id="@+id/layoutGameList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp" />
    </ScrollView>

</LinearLayout>
