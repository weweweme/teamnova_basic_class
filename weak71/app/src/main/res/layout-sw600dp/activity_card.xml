<?xml version="1.0" encoding="utf-8"?>
<!--
    [태블릿용 레이아웃 (sw600dp)]

    이 파일은 화면 최소 너비가 600dp 이상인 기기(태블릿)에서 자동으로 사용된다.
    스마트폰에서는 res/layout/activity_card.xml이 사용됨.

    태블릿에서는 화면이 넓으니 카드를 세로로 겹치지 않고 가로로 나란히 배치한다.
    같은 Activity, 같은 Java 코드지만 레이아웃만 다르게 보여주는 것이 핵심.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    tools:context=".CardActivity">

    <!-- 태블릿: 카드들을 가로로 나란히 배치 (LinearLayout으로 감싸서) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="horizontal"
        android:gravity="center">

        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="280dp"
            android:layout_weight="1"
            android:layout_margin="12dp"
            app:cardBackgroundColor="#FF7043"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="카드 1"
                android:textColor="#FFFFFF"
                android:textSize="20sp" />
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="280dp"
            android:layout_weight="1"
            android:layout_margin="12dp"
            app:cardBackgroundColor="#42A5F5"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="카드 2"
                android:textColor="#FFFFFF"
                android:textSize="20sp" />
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="280dp"
            android:layout_weight="1"
            android:layout_margin="12dp"
            app:cardBackgroundColor="#66BB6A"
            app:cardCornerRadius="16dp"
            app:cardElevation="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="카드 3"
                android:textColor="#FFFFFF"
                android:textSize="20sp" />
        </androidx.cardview.widget.CardView>

    </LinearLayout>

</FrameLayout>
