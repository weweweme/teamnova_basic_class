<?xml version="1.0" encoding="utf-8"?>
<!--
    ============================================================
    [Service / BroadcastReceiver 데모 레이아웃]
    ============================================================

    이 화면은 AndroidManifest.xml에 선언하는 2가지 핵심 컴포넌트를 체험한다:

    1) Service    = 화면 없이 백그라운드에서 실행되는 컴포넌트
       Unity 비유: 씬에 보이지 않지만 DontDestroyOnLoad()로
                   계속 살아있는 매니저 오브젝트의 코루틴과 같다.

    2) BroadcastReceiver = 시스템/앱 이벤트를 수신하는 컴포넌트
       Unity 비유: EventSystem의 EventTrigger/EventListener와 같다.
                   특정 이벤트가 발생하면 등록된 콜백이 호출된다.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".MetaDataActivity">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:title="서비스 / 리시버"
        app:navigationIcon="?attr/homeAsUpIndicator" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- ============================================================ -->
            <!-- 섹션 1: Service 데모                                          -->
            <!-- ============================================================ -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Service 데모 (포그라운드 서비스)"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#FF6200EE"
                        android:layout_marginBottom="12dp" />

                    <!-- 서비스 시작 버튼 -->
                    <Button
                        android:id="@+id/btnStartService"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="포그라운드 서비스 시작"
                        android:layout_marginBottom="8dp" />

                    <!-- 서비스 중지 버튼 -->
                    <Button
                        android:id="@+id/btnStopService"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="포그라운드 서비스 중지"
                        android:layout_marginBottom="12dp" />

                    <!-- 서비스 상태 + 실시간 카운터 표시 영역 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="#F5F5F5"
                        android:padding="12dp">

                        <TextView
                            android:id="@+id/tvServiceStatus"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="서비스 상태: 중지됨"
                            android:textSize="14sp"
                            android:textColor="#FF333333"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/tvServiceCounter"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="백그라운드 작업 횟수: 0회"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="#FF6200EE" />

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ============================================================ -->
            <!-- 섹션 2: BroadcastReceiver 데모                                -->
            <!-- ============================================================ -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="BroadcastReceiver 데모"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#FF6200EE"
                        android:layout_marginBottom="12dp" />

                    <!-- 리시버 등록 버튼 -->
                    <Button
                        android:id="@+id/btnRegisterReceiver"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="리시버 등록 (10초 간격 수신 시작)"
                        android:layout_marginBottom="8dp" />

                    <!-- 리시버 해제 버튼 -->
                    <Button
                        android:id="@+id/btnUnregisterReceiver"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="리시버 해제"
                        android:layout_marginBottom="12dp" />

                    <!-- 리시버 상태 + 수신 정보 표시 영역 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="#F5F5F5"
                        android:padding="12dp">

                        <TextView
                            android:id="@+id/tvReceiverStatus"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="리시버 상태: 미등록"
                            android:textSize="14sp"
                            android:textColor="#FF333333"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/tvTickCount"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="수신 횟수: 0"
                            android:textSize="14sp"
                            android:textColor="#FF333333"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/tvLastTick"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="마지막 수신: -"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="#FF6200EE" />

                    </LinearLayout>

                    <!-- 안내 문구 -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="sendBroadcast()로 10초마다 커스텀 브로드캐스트를 보내고,\nregisterReceiver()로 등록한 리시버가 수신합니다."
                        android:textSize="12sp"
                        android:textColor="#999999" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
