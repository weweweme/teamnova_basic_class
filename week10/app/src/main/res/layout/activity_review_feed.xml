<?xml version="1.0" encoding="utf-8"?>
<!-- 커뮤니티 "최근 리뷰" 전체 피드 화면 (홈의 "더 보기") -->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".community.ReviewFeedActivity">

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerReviewFeed"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingTop="8dp"
        android:paddingBottom="16dp"
        android:clipToPadding="false"
        tools:listitem="@layout/item_review_feed" />

    <TextView
        android:id="@+id/textViewFeedEmpty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="@string/review_feed_empty"
        android:textColor="#888888"
        android:visibility="gone" />

</FrameLayout>
