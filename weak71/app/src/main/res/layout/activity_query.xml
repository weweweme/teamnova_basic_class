<?xml version="1.0" encoding="utf-8"?>
<!--
    ============================================================
    [패키지 가시성 데모 레이아웃]
    ============================================================

    이 화면은 AndroidManifest.xml의 <queries> 요소를 체험한다.

    Android 11(API 30)부터 "패키지 가시성" 정책이 도입되었다:
    → 다른 앱이 설치되어 있는지 확인하려면 Manifest에 미리 선언해야 한다.
    → 선언하지 않으면 getPackageInfo()나 queryIntentActivities()가
      상대 앱을 "없는 것"으로 취급한다.

    Unity 비유:
    FindObjectsOfType<T>()를 호출할 때,
    특정 레이어의 오브젝트만 검색 대상으로 등록해야 찾을 수 있다고 상상하면 된다.
    등록하지 않은 레이어의 오브젝트는 아예 존재하지 않는 것처럼 취급된다.

    레이아웃 구조: ScrollView > LinearLayout(vertical) 안에 CardView 3개
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    tools:context=".QueryActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- ===== 화면 타이틀 ===== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="패키지 가시성 데모"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textAlignment="center"
            android:layout_marginBottom="16dp" />

        <!-- ============================================================ -->
        <!-- 섹션 1: 특정 앱 설치 확인                                      -->
        <!-- ============================================================ -->
        <!--
            Manifest에 <queries><package android:name="패키지명"/></queries> 를 선언하면
            해당 패키지의 설치 여부를 getPackageInfo()로 확인할 수 있다.

            선언하지 않으면 Android 11+에서는 NameNotFoundException이 발생한다.
            (실제로 설치되어 있어도!)

            Unity 비유: Physics.Raycast의 LayerMask와 비슷하다.
            오브젝트가 존재해도 LayerMask에 포함되지 않으면 감지되지 않는 것처럼,
            queries에 선언하지 않은 앱은 감지되지 않는다.
        -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="특정 앱 설치 확인"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <!--
                    Chrome 설치 여부를 확인한다.
                    Manifest의 <queries>에 com.android.chrome을 선언해야
                    Android 11+에서 정상적으로 감지된다.
                -->
                <TextView
                    android:id="@+id/tvChromeStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Chrome: 확인 중..."
                    android:textSize="14sp"
                    android:layout_marginBottom="6dp" />

                <!--
                    Google Maps 설치 여부를 확인한다.
                    마찬가지로 <queries>에 com.google.android.apps.maps를 선언해야 한다.
                -->
                <TextView
                    android:id="@+id/tvMapsStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Google Maps: 확인 중..."
                    android:textSize="14sp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ============================================================ -->
        <!-- 섹션 2: Intent를 처리할 수 있는 앱 목록                         -->
        <!-- ============================================================ -->
        <!--
            queryIntentActivities()로 특정 Intent를 처리할 수 있는 앱 목록을 조회한다.

            Manifest에 <queries><intent><action .../><data .../></intent></queries>를 선언해야
            해당 Intent를 처리할 수 있는 앱들이 목록에 나타난다.

            Unity 비유: Event를 수신할 수 있는 리스너 목록을 조회하는 것.
            EventSystem에서 "OnClick 이벤트를 받을 수 있는 오브젝트가 몇 개인가?"를
            확인하려면, 먼저 해당 이벤트 타입을 등록해야 하는 것과 비슷하다.
        -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Intent를 처리할 수 있는 앱"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <!-- https:// 링크를 열 수 있는 앱 수 -->
                <TextView
                    android:id="@+id/tvWebApps"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="https:// 링크를 열 수 있는 앱: 확인 중..."
                    android:textSize="14sp"
                    android:layout_marginBottom="6dp" />

                <!-- 텍스트 공유를 받을 수 있는 앱 수 -->
                <TextView
                    android:id="@+id/tvShareApps"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="텍스트 공유를 받을 수 있는 앱: 확인 중..."
                    android:textSize="14sp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ===== 새로고침 버튼 ===== -->
        <Button
            android:id="@+id/btnRefresh"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="새로고침" />

        <!-- ============================================================ -->
        <!-- 섹션 3: queries 설명 카드                                      -->
        <!-- ============================================================ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#E8F5E9">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="queries 요소란?"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Android 11(API 30) 이전:\n→ 어떤 앱이 설치되어 있는지 자유롭게 조회 가능\n→ 개인정보 우려: 설치된 앱 목록으로 사용자 성향 파악 가능\n\nAndroid 11(API 30) 이후:\n→ queries에 선언한 앱/Intent만 조회 가능\n→ 선언하지 않은 앱은 '존재하지 않음'으로 처리\n\n선언 방법:\n1. 특정 패키지: &lt;package android:name=&quot;...&quot;/&gt;\n2. Intent 패턴: &lt;intent&gt;&lt;action .../&gt;&lt;data .../&gt;&lt;/intent&gt;\n\nUnity 비유:\nFindObjectsOfType을 쓸 때 특정 레이어만\n검색 대상으로 지정하는 것과 같다.\n등록하지 않은 레이어는 아예 검색되지 않는다."
                    android:textSize="13sp"
                    android:lineSpacingExtra="3dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
