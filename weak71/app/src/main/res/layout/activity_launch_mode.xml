<?xml version="1.0" encoding="utf-8"?>
<!--
    ============================================================
    [launchMode 데모 레이아웃]
    ============================================================

    이 화면은 AndroidManifest.xml의 android:launchMode 속성을 체험한다.

    launchMode는 Activity가 이미 존재할 때 새로 만들지, 기존 것을 재사용할지를 결정한다.

    4가지 모드:
    1. standard (기본값): 매번 새 인스턴스를 생성한다.
       Unity 비유: Instantiate()를 호출할 때마다 새 오브젝트가 생기는 것.

    2. singleTop: 이미 맨 위(top)에 있으면 재사용한다 (onNewIntent 호출).
       Unity 비유: Singleton 패턴. 이미 존재하면 새로 만들지 않고 기존 것을 사용.
                   다만 "맨 위에 있을 때만" 재사용한다는 조건이 붙는다.

    3. singleTask: Task(작업 스택) 내에서 하나만 존재. 위에 있는 Activity들을 모두 제거.
       Unity 비유: DontDestroyOnLoad 씬에 하나만 존재하는 매니저 오브젝트.

    4. singleInstance: 자신만의 별도 Task에서 단독으로 실행된다.
       Unity 비유: 별도 프로세스(씬)에서 혼자 실행되는 독립적인 시스템.

    이 데모에서는 standard vs singleTop의 차이를 체험한다:
    - "자기 자신을 다시 열기" → standard 방식 (새 인스턴스 생성됨)
    - "FLAG_ACTIVITY_SINGLE_TOP으로 열기" → singleTop 방식 (기존 재사용)

    레이아웃 구조: LinearLayout(vertical) + ScrollView(이벤트 로그)
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    tools:context=".LaunchModeActivity">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:title="실행 모드"
        app:navigationIcon="?attr/homeAsUpIndicator" />

    <!-- ===== 화면 타이틀 ===== -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="launchMode 데모"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textAlignment="center"
        android:layout_marginBottom="16dp" />

    <!-- ============================================================ -->
    <!-- 인스턴스 정보 카드                                              -->
    <!-- ============================================================ -->
    <!--
        현재 Activity 인스턴스의 고유 정보를 표시한다.
        hashCode가 바뀌면 = 새 인스턴스가 생성된 것.
        hashCode가 같으면 = 기존 인스턴스가 재사용된 것.

        Unity 비유:
        GetInstanceID()가 같으면 같은 오브젝트,
        다르면 다른 오브젝트인 것과 동일한 원리.
    -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="#FFFFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="인스턴스 정보"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <!--
                hashCode: Java 객체의 고유 식별자 (메모리 주소 기반).
                새 인스턴스가 생성되면 hashCode가 바뀐다.
                Unity 비유: Object.GetInstanceID()
            -->
            <TextView
                android:id="@+id/tvHashCode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="인스턴스 hashCode: -"
                android:textSize="14sp"
                android:layout_marginBottom="4dp" />

            <!--
                Task ID: Activity가 속한 작업 스택의 ID.
                같은 Task에 있으면 같은 ID.
                Unity 비유: 씬 인덱스. 같은 씬에 있는 오브젝트들은 같은 씬 ID를 가진다.
            -->
            <TextView
                android:id="@+id/tvTaskId"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Task ID: -"
                android:textSize="14sp"
                android:layout_marginBottom="4dp" />

            <!--
                onCreate 호출 횟수: 새 인스턴스가 생성될 때마다 증가.
                static 변수이므로 앱이 살아있는 동안 누적된다.
            -->
            <TextView
                android:id="@+id/tvCreateCount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="onCreate 호출 횟수: 0"
                android:textSize="14sp"
                android:layout_marginBottom="4dp" />

            <!--
                onNewIntent 호출 횟수: singleTop으로 기존 인스턴스가 재사용될 때 증가.
                onCreate 대신 onNewIntent가 호출된다.
            -->
            <TextView
                android:id="@+id/tvNewIntentCount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="onNewIntent 호출 횟수: 0"
                android:textSize="14sp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ===== 자기 자신을 다시 열기 (standard 방식) ===== -->
    <!--
        일반 startActivity()로 자기 자신을 다시 연다.
        launchMode가 standard이면 매번 새 인스턴스가 스택에 쌓인다.

        Unity 비유: 같은 씬을 SceneManager.LoadScene(Additive)로 중복 로드하는 것.
        뒤로가기를 누르면 이전 인스턴스로 돌아간다 (스택에서 pop).
    -->
    <Button
        android:id="@+id/btnRelaunchSelf"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="2dp"
        android:text="액티비티 열기: standard (기본값)" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="→ hashCode 변경, onCreate 증가"
        android:textSize="12sp"
        android:textColor="#757575"
        android:layout_marginBottom="12dp"
        android:paddingStart="4dp"
        android:paddingEnd="4dp" />

    <!-- ===== singleTop ===== -->
    <!--
        FLAG_ACTIVITY_SINGLE_TOP: 이미 맨 위에 있으면 재사용 (onNewIntent 호출).
        Manifest의 launchMode="singleTop"과 같은 효과.
    -->
    <Button
        android:id="@+id/btnRelaunchWithFlag"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="2dp"
        android:text="액티비티 열기: singleTop" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="→ hashCode 불변, onNewIntent 증가"
        android:textSize="12sp"
        android:textColor="#757575"
        android:layout_marginBottom="12dp"
        android:paddingStart="4dp"
        android:paddingEnd="4dp" />

    <!-- ===== singleTask ===== -->
    <!--
        FLAG_ACTIVITY_CLEAR_TOP + FLAG_ACTIVITY_SINGLE_TOP:
        이미 스택에 존재하면 그 위의 모든 Activity를 제거하고 재사용.
        Manifest의 launchMode="singleTask"와 유사한 효과.
    -->
    <Button
        android:id="@+id/btnSingleTask"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="2dp"
        android:text="액티비티 열기: singleTask" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="→ 위에 쌓인 인스턴스 모두 제거, 기존 인스턴스 재사용"
        android:textSize="12sp"
        android:textColor="#757575"
        android:layout_marginBottom="12dp"
        android:paddingStart="4dp"
        android:paddingEnd="4dp" />

    <!-- ===== singleInstance ===== -->
    <!--
        FLAG_ACTIVITY_NEW_TASK: 별도의 Task(스택)에서 실행.
        Manifest의 launchMode="singleInstance"와 유사한 효과.
    -->
    <Button
        android:id="@+id/btnSingleInstance"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="2dp"
        android:text="액티비티 열기: singleInstance" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="→ Task ID 변경 (별도 스택에서 실행)"
        android:textSize="12sp"
        android:textColor="#757575"
        android:layout_marginBottom="12dp"
        android:paddingStart="4dp"
        android:paddingEnd="4dp" />

    <!-- ============================================================ -->
    <!-- 이벤트 로그 (시간순으로 기록)                                     -->
    <!-- ============================================================ -->
    <!--
        onCreate, onNewIntent가 호출될 때마다 타임스탬프와 함께 기록한다.
        hashCode가 바뀌는지, onCreate vs onNewIntent 어떤 것이 호출되는지 관찰.
        ScrollView로 감싸서 로그가 많아져도 스크롤 가능.
    -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#F5F5F5"
        android:padding="8dp">

        <TextView
            android:id="@+id/tvEventLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="이벤트 로그:"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:lineSpacingExtra="2dp" />

    </ScrollView>

</LinearLayout>
