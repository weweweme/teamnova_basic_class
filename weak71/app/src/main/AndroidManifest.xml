<?xml version="1.0" encoding="utf-8"?>
<!--
    [AndroidManifest.xml - 앱의 신분증]

    Android 앱의 모든 구성요소(Activity, Service 등)는 여기에 등록해야 시스템이 인식한다.
    등록하지 않은 Activity를 Intent로 호출하면 크래시가 발생한다.

    Unity 비유: Build Settings의 "Scenes In Build" 목록과 유사.
    씬을 빌드 목록에 안 넣으면 로드할 수 없는 것처럼,
    Activity를 Manifest에 등록하지 않으면 실행할 수 없다.

    공식 문서: https://developer.android.com/guide/topics/manifest/manifest-intro
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!--
        [application] - 앱 전체에 대한 설정

        android:allowBackup     → 앱 데이터 백업 허용 여부
        android:icon            → 앱 아이콘 (홈 화면에 보이는 아이콘)
        android:label           → 앱 이름 (홈 화면에 표시되는 텍스트)
        android:roundIcon       → 원형 아이콘 지원 기기에서 사용되는 아이콘
        android:supportsRtl     → RTL(오른쪽→왼쪽) 언어 지원 (아랍어 등)
        android:theme           → 앱 전체에 적용되는 기본 테마 (색상, 스타일 등)
    -->
    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Weak71">

        <!--
            [exported="false"] → 이 Activity는 외부 앱에서 호출할 수 없다 (내부 전용).
            [exported="true"]  → 외부에서 호출 가능. LAUNCHER Activity는 반드시 true여야 한다.
        -->

        <!-- 카드 겹침 화면 (FrameLayout) -->
        <activity
            android:name=".CardActivity"
            android:exported="false" />

        <!-- 계산기 화면 (GridLayout) -->
        <activity
            android:name=".CalculatorActivity"
            android:exported="false" />

        <!-- 설정 화면 (ScrollView) -->
        <activity
            android:name=".SettingActivity"
            android:exported="false" />

        <!-- 프로필 화면 (ConstraintLayout) -->
        <activity
            android:name=".ProfileActivity"
            android:exported="false" />

        <!-- 로그인 화면 (LinearLayout) -->
        <activity
            android:name=".LoginActivity"
            android:exported="false" />

        <!--
            [HomeActivity - 앱 시작 화면 (LAUNCHER)]

            intent-filter로 이 Activity가 앱의 진입점임을 선언한다.
            - action.MAIN → 이 Activity가 앱의 메인 진입점
            - category.LAUNCHER → 홈 화면 런처(앱 서랍)에 아이콘을 표시

            이 두 가지가 함께 있어야 앱 아이콘을 눌렀을 때 이 화면이 뜬다.
            Unity 비유: Build Settings에서 맨 위에 있는 씬(index 0)이 시작 씬인 것과 동일.
        -->
        <activity
            android:name=".HomeActivity"
            android:exported="true"
            android:theme="@style/Theme.Weak71">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
