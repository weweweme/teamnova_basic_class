<?xml version="1.0" encoding="utf-8"?>
<!-- '내 일지' 탭 화면 (개인 기록 허브) -->
<!-- 바깥은 ScrollView(세로 스크롤), 안에 섹션들을 세로로 쌓음 -->
<!-- 각 섹션의 미리보기는 가로 스크롤 RecyclerView → "세로 안에 가로" = 중첩 스크롤 구조 -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".home.HomeFragment">

    <!-- ScrollView는 자식을 하나만 가질 수 있으므로 LinearLayout으로 감쌈 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="8dp"
        android:paddingBottom="16dp">

        <!-- ════════ 프로필 헤더 (아바타 + 별명 + 한 줄 소개) ════════ -->
        <!-- 탭하면 ProfileEditActivity로 이동 → clickable + foreground 리플 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardProfile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginTop="8dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">

                <!-- 아바타 (사진 있으면 사진, 없으면 색+첫글자) -->
                <FrameLayout
                    android:layout_width="56dp"
                    android:layout_height="56dp">

                    <!-- 기본: 색깔 원 + 별명 첫 글자 (색은 코드에서 backgroundTintList로 칠함) -->
                    <TextView
                        android:id="@+id/textViewAvatarHome"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_avatar_circle"
                        android:gravity="center"
                        android:textColor="#FFFFFF"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        tools:text="A" />

                    <!-- 프로필 사진 (카카오 등) — 있을 때만 코드에서 표시. 원형 배경 + clipToOutline로 동그랗게 -->
                    <ImageView
                        android:id="@+id/imageViewAvatarHome"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_avatar_circle"
                        android:scaleType="centerCrop"
                        android:contentDescription="@string/profile_avatar_placeholder"
                        android:visibility="gone" />
                </FrameLayout>

                <!-- 별명 + 한 줄 소개 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/textViewNicknameHome"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        tools:text="앨리스" />

                    <TextView
                        android:id="@+id/textViewBioHome"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textColor="#888888"
                        android:textSize="13sp"
                        tools:text="인디 게임 좋아합니다" />

                    <!-- 출석/방문 (연속 일수 · 누적 횟수) -->
                    <TextView
                        android:id="@+id/textViewAttendanceHome"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textColor="#EF6C00"
                        android:textSize="12sp"
                        tools:text="🔥 3일 연속 · 누적 12회 방문" />

                    <!-- 팔로잉 · 팔로워 (각각 눌러 목록으로) -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/textViewFollowingHome"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="?attr/selectableItemBackground"
                            android:paddingTop="2dp"
                            android:paddingBottom="2dp"
                            android:paddingEnd="4dp"
                            android:textColor="#666666"
                            android:textSize="12sp"
                            tools:text="팔로잉 2" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingTop="2dp"
                            android:paddingBottom="2dp"
                            android:text="·"
                            android:textColor="#666666"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/textViewFollowerHome"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="?attr/selectableItemBackground"
                            android:paddingStart="4dp"
                            android:paddingTop="2dp"
                            android:paddingBottom="2dp"
                            android:textColor="#666666"
                            android:textSize="12sp"
                            tools:text="팔로워 3" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ════════ 내 통계 (제목 + 더 보기) ════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="8dp"
            android:paddingTop="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/home_section_stats"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- 더 보기 → StatsActivity -->
            <Button
                android:id="@+id/buttonMoreStats"
                style="?attr/borderlessButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home_more"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- ════════ 통계 요약 카드 (내 게임 현황 한눈에) ════════ -->
        <!-- 4칸(전체/완료/플레이중/찜 목록)을 가로 균등 배치, 숫자는 코드에서 채움 -->
        <!-- 탭하면 StatsActivity(상세 통계)로 이동 → clickable + foreground 리플 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardStats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginTop="4dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="16dp"
                android:paddingBottom="16dp">

                <!-- 전체 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/textViewStatTotal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/home_stat_total"
                        android:textColor="#888888"
                        android:textSize="12sp" />
                </LinearLayout>

                <!-- 완료 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/textViewStatCompleted"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#2E7D32"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/home_stat_completed"
                        android:textColor="#888888"
                        android:textSize="12sp" />
                </LinearLayout>

                <!-- 플레이중 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/textViewStatPlaying"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#1565C0"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/home_stat_playing"
                        android:textColor="#888888"
                        android:textSize="12sp" />
                </LinearLayout>

                <!-- 찜 목록 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/textViewStatBacklog"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#EF6C00"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/home_stat_backlog"
                        android:textColor="#888888"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ════════ 섹션 0: 최근 본 게임 ════════ -->
        <!-- 게임 상세를 연 순서대로(최신순) 표지를 가로로 나열 -->
        <!-- 아직 본 게임이 없으면 코드에서 이 컨테이너를 통째로 숨김(GONE) -->
        <LinearLayout
            android:id="@+id/layoutRecentViewed"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingTop="16dp"
                android:text="@string/home_section_recent"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- clipToPadding=true: 스크롤해도 카드가 좌우 패딩 안쪽에서 잘려 양쪽 끝 여백 유지 -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerRecentViewed"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:clipToPadding="true"
                tools:listitem="@layout/item_library_grid" />
        </LinearLayout>

        <!-- ════════ 섹션 1: 보관함 미리보기 ════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="8dp"
            android:paddingTop="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/home_section_library"
                android:textSize="18sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/buttonMoreLibrary"
                style="?attr/borderlessButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home_more"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- clipToPadding=true: 마퀴로 흘러도 카드가 좌우 패딩 안쪽에서 잘려 양쪽 끝 여백이 항상 유지됨 -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerLibraryPreview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:clipToPadding="true"
            tools:listitem="@layout/item_library_grid" />

        <!-- ════════ 섹션 3: 최근 활동(타임라인) 미리보기 ════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="8dp"
            android:paddingTop="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/home_section_timeline"
                android:textSize="18sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/buttonMoreTimeline"
                style="?attr/borderlessButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home_more"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- 타임라인 미리보기는 세로 일부 (TimelineAdapter 재사용, 세로 LinearLayoutManager) -->
        <!-- 바깥 ScrollView 안에서 자체 스크롤하지 않도록 HomeFragment에서 nestedScrolling 비활성 -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerTimelinePreview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            tools:listitem="@layout/item_log_completed" />

    </LinearLayout>

</ScrollView>
