<?xml version="1.0" encoding="utf-8"?>
<!-- 라이브러리 화면 레이아웃 -->
<!-- 상단: 상태별 필터 탭(TabLayout) / 하단: 게임 표지 격자(RecyclerView + GridLayoutManager) -->
<!-- 탭을 누르면 해당 상태의 게임만 격자에 표시됨 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".LibraryActivity">

    <!-- 상태별 필터 탭 (전체/플레이중/완료/중단/백로그) -->
    <!-- 탭이 많아 가로로 넘칠 수 있으니 tabMode=scrollable -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayoutFilter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:tabMode="scrollable" />

    <!-- 표지 격자 영역 (탭으로 필터된 게임 표시) -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerViewLibrary"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="6dp"
            android:clipToPadding="false"
            tools:listitem="@layout/item_library_grid" />

        <!-- 빈 상태 안내 (해당 상태의 게임이 없을 때만 표시) -->
        <TextView
            android:id="@+id/textViewEmpty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/library_empty"
            android:textColor="#888888"
            android:textSize="15sp"
            android:visibility="gone" />
    </FrameLayout>

</LinearLayout>
