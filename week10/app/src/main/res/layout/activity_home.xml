<?xml version="1.0" encoding="utf-8"?>
<!-- 홈 화면 (허브) 레이아웃 -->
<!-- 바깥은 ScrollView(세로 스크롤), 안에 섹션 3개를 세로로 쌓음 -->
<!-- 각 섹션의 미리보기는 가로 스크롤 RecyclerView → "세로 안에 가로" = 중첩 스크롤 구조 -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".home.HomeActivity">

    <!-- ScrollView는 자식을 하나만 가질 수 있으므로 LinearLayout으로 감쌈 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="8dp"
        android:paddingBottom="16dp">

        <!-- ════════ 프로필 헤더 (아바타 + 별명 + 한 줄 소개) ════════ -->
        <!-- 탭하면 ProfileEditActivity로 이동 → clickable + foreground 리플 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardProfile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginTop="8dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">

                <!-- 아바타 (색 + 별명 첫 글자) — 색은 코드에서 backgroundTintList로 칠함 -->
                <TextView
                    android:id="@+id/textViewAvatarHome"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:background="@drawable/bg_avatar_circle"
                    android:gravity="center"
                    android:textColor="#FFFFFF"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    tools:text="A" />

                <!-- 별명 + 한 줄 소개 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/textViewNicknameHome"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        tools:text="앨리스" />

                    <TextView
                        android:id="@+id/textViewBioHome"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textColor="#888888"
                        android:textSize="13sp"
                        tools:text="인디 게임 좋아합니다" />

                    <!-- 출석/방문 (연속 일수 · 누적 횟수) -->
                    <TextView
                        android:id="@+id/textViewAttendanceHome"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textColor="#EF6C00"
                        android:textSize="12sp"
                        tools:text="🔥 3일 연속 · 누적 12회 방문" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ════════ 내 통계 (제목 + 더 보기) ════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="8dp"
            android:paddingTop="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/home_section_stats"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- 더 보기 → StatsActivity -->
            <Button
                android:id="@+id/buttonMoreStats"
                style="?attr/borderlessButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home_more"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- ════════ 통계 요약 카드 (내 게임 현황 한눈에) ════════ -->
        <!-- 4칸(전체/완료/플레이중/찜 목록)을 가로 균등 배치, 숫자는 코드에서 채움 -->
        <!-- 탭하면 StatsActivity(상세 통계)로 이동 → clickable + foreground 리플 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardStats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginTop="4dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="16dp"
                android:paddingBottom="16dp">

                <!-- 전체 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/textViewStatTotal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/home_stat_total"
                        android:textColor="#888888"
                        android:textSize="12sp" />
                </LinearLayout>

                <!-- 완료 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/textViewStatCompleted"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#2E7D32"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/home_stat_completed"
                        android:textColor="#888888"
                        android:textSize="12sp" />
                </LinearLayout>

                <!-- 플레이중 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/textViewStatPlaying"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#1565C0"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/home_stat_playing"
                        android:textColor="#888888"
                        android:textSize="12sp" />
                </LinearLayout>

                <!-- 찜 목록 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/textViewStatBacklog"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#EF6C00"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/home_stat_backlog"
                        android:textColor="#888888"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ════════ 섹션 1: 보관함 미리보기 ════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="8dp"
            android:paddingTop="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/home_section_library"
                android:textSize="18sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/buttonMoreLibrary"
                style="?attr/borderlessButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home_more"
                android:textSize="13sp" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerLibraryPreview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:clipToPadding="false"
            tools:listitem="@layout/item_library_grid" />

        <!-- ════════ 섹션 3: 최근 활동(타임라인) 미리보기 ════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="8dp"
            android:paddingTop="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/home_section_timeline"
                android:textSize="18sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/buttonMoreTimeline"
                style="?attr/borderlessButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home_more"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- 타임라인 미리보기는 세로 일부 (TimelineAdapter 재사용, 세로 LinearLayoutManager) -->
        <!-- 바깥 ScrollView 안에서 자체 스크롤하지 않도록 HomeActivity에서 nestedScrolling 비활성 -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerTimelinePreview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            tools:listitem="@layout/item_log_completed" />

        <!-- ════════ 섹션 4: 최근 리뷰(커뮤니티 피드) 미리보기 ════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="8dp"
            android:paddingTop="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/home_section_feed"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- 더 보기 → 전체 리뷰 피드 -->
            <Button
                android:id="@+id/buttonMoreFeed"
                style="?attr/borderlessButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home_more"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- 최근 리뷰 미리보기 (세로 일부, 자체 스크롤 끔) -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerReviewFeed"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            tools:listitem="@layout/item_review_feed" />

    </LinearLayout>

</ScrollView>
