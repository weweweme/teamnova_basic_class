<?xml version="1.0" encoding="utf-8"?>
<!-- MainActivity의 ActionBar 메뉴 -->
<!-- "게임 추가": + 아이콘으로 ActionBar에 바로 표시 (showAsAction="always") -->
<!-- "앱 정보": 오버플로우 메뉴(⋮)에 숨김 표시 (showAsAction="never") -->
<!-- Unity로 비유하면 우클릭 컨텍스트 메뉴를 미리 리소스로 정의하는 것 -->
<menu xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <!-- 그리드/리스트 보기 토글: 현재 모드의 "반대" 아이콘을 표시 -->
    <item
        android:id="@+id/action_view_toggle"
        android:icon="@drawable/ic_view_list"
        android:title="@string/library_view_toggle"
        app:showAsAction="always" />

    <!-- 검색: 돋보기 아이콘 → 탭하면 SearchView 펼쳐짐 (제목 실시간 검색) -->
    <!-- collapseActionView: 평소엔 아이콘, 탭하면 입력창으로 펼쳐지고 ←로 접힘 -->
    <item
        android:id="@+id/action_search"
        android:icon="@android:drawable/ic_menu_search"
        android:title="@string/library_search_hint"
        app:showAsAction="always|collapseActionView"
        app:actionViewClass="androidx.appcompat.widget.SearchView" />

    <!-- 게임 추가: + 아이콘이 ActionBar 우측에 바로 보임 -->
    <item
        android:id="@+id/action_add_game"
        android:icon="@android:drawable/ic_input_add"
        android:title="@string/main_add_game"
        app:showAsAction="always" />

    <!-- 앱 정보: ⋮ 오버플로우 메뉴 안에 숨김 -->
    <item
        android:id="@+id/action_about"
        android:title="@string/about_menu_label"
        app:showAsAction="never" />

</menu>
