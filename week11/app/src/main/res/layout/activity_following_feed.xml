<?xml version="1.0" encoding="utf-8"?>
<!-- 팔로잉 피드 화면 (내가 팔로우한 사람들의 리뷰 최신순) -->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".community.FollowingFeedActivity">

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerFollowingFeed"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingTop="8dp"
        android:paddingBottom="16dp"
        android:clipToPadding="false"
        tools:listitem="@layout/item_review_feed" />

    <TextView
        android:id="@+id/textViewFollowingFeedEmpty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:text="@string/following_feed_empty"
        android:textColor="#888888"
        android:visibility="gone" />

    <!-- 로딩 스피너 (피드 집계 중 중앙 표시, 평소엔 숨김) -->
    <ProgressBar
        android:id="@+id/progressFollowingFeed"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

</FrameLayout>
