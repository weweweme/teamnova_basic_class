<?xml version="1.0" encoding="utf-8"?>
<!-- 하단 탭 항목 (BottomNavigationView가 이 메뉴를 탭 버튼으로 그림) -->
<!-- 항목 하나 = 탭 하나. id로 어떤 탭이 눌렸는지 코드에서 구분 -->
<menu xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 내 일지 탭 (개인 기록: 홈/보관함/통계/최근활동) -->
    <item
        android:id="@+id/tab_diary"
        android:icon="@drawable/ic_tab_diary"
        android:title="@string/tab_diary" />

    <!-- 커뮤니티 탭 (소셜: 팔로잉 피드 + 랭킹) -->
    <item
        android:id="@+id/tab_community"
        android:icon="@drawable/ic_tab_community"
        android:title="@string/tab_community" />

</menu>
