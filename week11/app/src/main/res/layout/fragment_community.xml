<?xml version="1.0" encoding="utf-8"?>
<!-- '커뮤니티' 탭 (소셜 — 감초 역할) -->
<!-- 위: 제목 + 🏆 랭킹 진입 버튼 / 아래: 팔로잉 피드(당겨서 새로고침) -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".community.CommunityFragment">

    <!-- ════════ 상단 헤더 (제목 + 랭킹 진입) ════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="8dp"
        android:paddingTop="12dp"
        android:paddingBottom="4dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/following_feed_title"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- 🏆 랭킹 → RankingActivity (감초: 작은 진입 하나) -->
        <Button
            android:id="@+id/buttonRanking"
            style="?attr/borderlessButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/community_ranking_button"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- ════════ 팔로잉 피드 (당겨서 새로고침) ════════ -->
    <!-- weight=1 → 헤더를 뺀 나머지 공간을 전부 차지 -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- 당겨서 새로고침: RecyclerView를 감싸면 위로 당길 때 새로고침 스피너가 나옴 -->
        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/swipeCommunityFeed"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerCommunityFeed"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingTop="8dp"
                android:paddingBottom="16dp"
                android:clipToPadding="false"
                tools:listitem="@layout/item_review_feed" />
        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

        <!-- 빈 상태 안내 (팔로우한 사람의 리뷰가 없을 때) -->
        <TextView
            android:id="@+id/textViewCommunityFeedEmpty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:text="@string/following_feed_empty"
            android:textColor="#888888"
            android:visibility="gone" />

        <!-- 로딩 스피너 (피드 집계 중 중앙 표시, 평소엔 숨김) -->
        <ProgressBar
            android:id="@+id/progressCommunityFeed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone" />

        <!-- "새 리뷰 N개 ↑" 알림 pill (상단 가운데에 떠 있음, 평소엔 숨김) -->
        <!-- 폴링으로 새 글을 발견하면 화면을 확 바꾸지 않고 이 pill만 띄운다 → 탭하면 맨 위로 로드 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonNewReviews"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="2dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="11dp"
            android:paddingBottom="11dp"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:visibility="gone"
            app:backgroundTint="#1565C0"
            app:cornerRadius="26dp"
            app:elevation="6dp"
            tools:text="새 리뷰 2개 ↑"
            tools:visibility="visible" />

    </FrameLayout>

</LinearLayout>
